# === Tastytrade API (required for scanner, discovery, monitors, review) ===
# Option A: single compact string (colon-separated)
TASTYTRADE_CREDS=client_secret:refresh_token

# Option B: separate variables
# TASTYTRADE_CLIENT_SECRET=your_client_secret
# TASTYTRADE_REFRESH_TOKEN=your_refresh_token

# Option C: path to creds file (legacy)
# TASTYTRADE_CREDS_FILE=~/.hermes/tastytrade_creds.env

# === Google Sheets (required for position monitors and review) ===
TRADE_LEDGER_SHEET_ID=your_google_sheet_id
GOOGLE_TOKEN_FILE=google_token.json

# === File paths (optional, defaults shown) ===
# CSP_UNIVERSE_FILE=data/csp_universe.json
# CSP_CANDIDATES_FILE=data/csp_candidates.json
# NEWS_TICKERS_CONFIG=data/news_tickers.json
